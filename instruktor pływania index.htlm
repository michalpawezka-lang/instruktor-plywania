 <!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Instruktor Pływania Michał</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<header class="hero">
  <div>
    <h1>Instruktor Pływania Michał</h1>
    <p>Rzeszów</p>
  </div>
</header>

<section id="rezerwacje">
  <h2>Rezerwacje lekcji</h2>
  <div id="calendar"></div>
</section>

<section id="kontakt">
  <h2>Kontakt</h2>
  <div class="box">
    <p><b>Telefon:</b> 502 532 605</p>
    <p><b>Miasto:</b> Rzeszów</p>
  </div>
</section>

<footer>
  © 2026 Instruktor Pływania Michał
</footer>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
import { getFirestore, collection, addDoc, query, where, getDocs } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyAclnGEqvK5w6lZbr2g-u9TItaQwwjd-bo",
  authDomain: "projekt-plywanie-a02d8.firebaseapp.com",
  projectId: "projekt-plywanie-a02d8",
  storageBucket: "projekt-plywanie-a02d8.firebasestorage.app",
  messagingSenderId: "357063939995",
  appId: "1:357063939995:web:67038b0ce3ba27aa0fb33e"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

const days = [
  "Poniedziałek","Wtorek","Środa",
  "Czwartek","Piątek","Sobota","Niedziela"
];

const hours = [
  "06:15","17:00","17:45","18:30","19:15","20:00","20:45"
];

const calendar = document.getElementById("calendar");

async function loadCalendar() {
  calendar.innerHTML = "";

  for (const day of days) {

    const box = document.createElement("div");
    box.className = "day";

    const title = document.createElement("h3");
    title.innerText = day;

    const slots = document.createElement("div");
    slots.className = "slots";

    for (const hour of hours) {

      const q = await getDocs(query(
        collection(db,"rezerwacje"),
        where("day","==",day),
        where("time","==",hour)
      ));

      const el = document.createElement("div");
      el.className = "slot";

      if (!q.empty) {
        el.classList.add("busy");
        el.innerText = hour + " ❌";
      } else {
        el.classList.add("free");
        el.innerText = hour + " ✔";

        el.onclick = () => book(day, hour);
      }

      slots.appendChild(el);
    }

    box.appendChild(title);
    box.appendChild(slots);
    calendar.appendChild(box);
  }
}

window.book = async function(day, time) {

  const name = prompt("Imię i nazwisko:");
  const phone = prompt("Telefon:");

  if (!name || !phone) return;

  const check = await getDocs(query(
    collection(db,"rezerwacje"),
    where("day","==",day),
    where("time","==",time)
  ));

  if (!check.empty) {
    alert("Ten termin jest już zajęty!");
    return;
  }

  await addDoc(collection(db,"rezerwacje"),{
    name,
    phone,
    day,
    time
  });

  alert("Zarezerwowano!");
  loadCalendar();
};

loadCalendar();
</script>

</body>
</html>